      "max_steps": 14,
      "services": ["search-api", "search-indexer"],
      "primary_service": "search-api",
      "log_message": "OutOfMemoryError: heap usage exceeded after build 2.3.1.",
      "success_reason": "Traffic drained and search API rolled back to stable build.",
      "alerts": [
        {
          "id": "A-301",
          "service": "search-api",
          "severity": "sev1",
          "summary": "Search API memory leak detected"
        },
        {
          "id": "A-302",
          "service": "search-api",
          "severity": "sev1",
          "summary": "Search p99 latency above SLO"
        }
      ],
      "metrics": {
        "search-api": {
          "memory_mb": 9800,
          "p99_latency_ms": 1850,
          "error_pct": 9.0
        },
        "search-indexer": {
          "error_pct": 0.8,
          "queue_lag_s": 12
        }
      },
      "healthy_metrics": {
