          "memory_mb": 1200,
          "p99_latency_ms": 210,
          "error_pct": 0.5
        },
        "search-indexer": {
          "error_pct": 0.3,
          "queue_lag_s": 4
        }
      },
      "runbook": {
        "search-api": [
